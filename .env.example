# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smart_attendance
DB_PASSWORD=postgres

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_REFRESH_SECRET=your-jwt-refresh-secret-change-in-production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Anthropic AI
ANTHROPIC_API_KEY=your-anthropic-api-key

# App
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Web Push (generate with web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@smartattendance.com
